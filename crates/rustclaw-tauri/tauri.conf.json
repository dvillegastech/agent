{
  "$schema": "https://raw.githubusercontent.com/nicedoc/schemastore/refs/heads/master/src/schemas/json/tauri-v2.json",
  "productName": "RustClaw",
  "version": "0.2.0",
  "identifier": "com.rustclaw.agent",
  "build": {
    "frontendDist": "./dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "windows": [
      {
        "title": "RustClaw Agent",
        "width": 900,
        "height": 700,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
